# Laptop local Cityverse service notes
# Copy to: config/network/laptop.cityverse.env
# This file is mainly for human/operator clarity and repeatable startup notes.

# Current laptop network identity
LAPTOP_HOST_LABEL=martin-laptop
LAPTOP_LAN_IP=192.168.8.20
LAPTOP_TAILSCALE_NAME=martin-laptop.tailnet-example.ts.net
LAPTOP_TAILSCALE_IP=100.101.102.103

# Local bind settings for laptop-host services
HOST=0.0.0.0
MQTT_URL=mqtt://localhost:1883
VC_PORT=3001
IOT_PORT=3002
DT_PORT=3003

# Notes:
# - VC/IOT already default to HOST=0.0.0.0 in this repo's start scripts.
# - DT exposure depends on the Unity/DT runtime you are using.
