# Syntra travel config — Mac mini runtime side
# Canonical machine split:
# - Mac mini runs OpenClaw, Syntra, VC, IOT, avatar bridge
# - Workstation runs Unity avatar / 3D display / optional DT

# Network identity
CITYVERSE_PROFILE=travel-lan
MAC_MINI_IP=192.168.1.197
WORKSTATION_IP=192.168.1.27

# Fixed ports
CITYVERSE_VC_PORT=3001
CITYVERSE_IOT_PORT=3002
CITYVERSE_DT_PORT=3003
AVATAR_BRIDGE_PORT=3099
WORKSTATION_AVATAR_WS_PORT=8787
OPENCLAW_PORT=18789

# Runtime service URLs as seen from the Mac mini
CITYVERSE_VC_BASE_URL=http://127.0.0.1:${CITYVERSE_VC_PORT}
CITYVERSE_IOT_BASE_URL=http://127.0.0.1:${CITYVERSE_IOT_PORT}
CITYVERSE_DT_BASE_URL=http://${WORKSTATION_IP}:${CITYVERSE_DT_PORT}

# Avatar output path
AVATAR_WS_URL=ws://${WORKSTATION_IP}:${WORKSTATION_AVATAR_WS_PORT}/avatar
AVATAR_BRIDGE_PUBLIC_BASE_URL=http://${MAC_MINI_IP}:${AVATAR_BRIDGE_PORT}

# Bridge TTS settings (macOS `say`)
AVATAR_TTS_MODE=say
AVATAR_TTS_VOICE=Samantha
AVATAR_TTS_RATE=175

# Mac mini public OpenClaw URL for other machines/tools if needed
MAC_MINI_OPENCLAW_URL=http://${MAC_MINI_IP}:${OPENCLAW_PORT}
