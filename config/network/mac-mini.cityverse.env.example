# Mac mini → Cityverse laptop connectivity
# Copy to: config/network/mac-mini.cityverse.env
# Then edit values for the current network.

# Profile label: lan | tailscale | fallback
CITYVERSE_PROFILE=travel-mini-lan

# Local/remote service URLs as seen from the Mac mini
CITYVERSE_VC_BASE_URL=http://127.0.0.1:3001
CITYVERSE_IOT_BASE_URL=http://127.0.0.1:3002
CITYVERSE_DT_BASE_URL=http://192.168.8.20:3003

# Workstation avatar receiver
AVATAR_WS_URL=ws://192.168.8.20:8787/avatar
AVATAR_BRIDGE_PUBLIC_BASE_URL=http://192.168.8.10:3099

# Optional docs override if needed
# CITYVERSE_DOCS_ROOT=/Users/martinsaldert/.openclaw/workspace-main/projects/Cityverse_MVP/docs
