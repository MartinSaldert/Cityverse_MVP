# Syntra travel config — Workstation receiver side
# This is primarily an operator/reference config for the Unity avatar workstation.

# Network identity
CITYVERSE_PROFILE=travel-lan
WORKSTATION_IP=192.168.1.27
MAC_MINI_IP=192.168.1.197

# Fixed ports
WORKSTATION_AVATAR_WS_PORT=8787
DT_PORT=3003
AVATAR_BRIDGE_PORT=3099
OPENCLAW_PORT=18789

# Current workstation receiver endpoint
WORKSTATION_AVATAR_WS_URL=ws://${WORKSTATION_IP}:${WORKSTATION_AVATAR_WS_PORT}/avatar

# How the workstation reaches the Mac mini
MAC_MINI_BRIDGE_BASE_URL=http://${MAC_MINI_IP}:${AVATAR_BRIDGE_PORT}
MAC_MINI_OPENCLAW_URL=http://${MAC_MINI_IP}:${OPENCLAW_PORT}

# Optional DT local URL if DT is running on the workstation
WORKSTATION_DT_BASE_URL=http://${WORKSTATION_IP}:${DT_PORT}
