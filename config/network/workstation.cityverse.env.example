# Workstation local Cityverse + avatar service notes
# Copy to: config/network/workstation.cityverse.env
# This file is mainly for human/operator clarity and repeatable startup notes.

# Current workstation network identity
WORKSTATION_HOST_LABEL=martin-workstation
WORKSTATION_LAN_IP=192.168.8.20
WORKSTATION_TAILSCALE_NAME=martin-workstation.tailnet-example.ts.net
WORKSTATION_TAILSCALE_IP=100.101.102.103

# Local workstation notes
WORKSTATION_AVATAR_WS_PORT=8787
DT_PORT=3003
MAC_MINI_BRIDGE_BASE_URL=http://192.168.8.10:3099
MAC_MINI_OPENCLAW_URL=http://192.168.8.10:18789

# Notes:
# - Unity avatar receiver listens locally on the workstation, e.g. ws://0.0.0.0:8787/avatar
# - DT exposure depends on the Unity/DT runtime you are using.
# - Audio for speech playback is fetched by Unity from the Mac mini bridge.
